###############################################################################
# Tailor Studio (Spring Boot) - environment variables template
#
# Copy this file to ".env" (same folder) and fill values.
# Do NOT commit ".env" (it is ignored by .gitignore).
#
# Notes:
# - Spring Boot relaxed binding maps:
#   phonepe.client-id      -> PHONEPE_CLIENT_ID
#   phonepe.client-secret  -> PHONEPE_CLIENT_SECRET
#   phonepe.merchant-id    -> PHONEPE_MERCHANT_ID
#   phonepe.redirect-base-url -> PHONEPE_REDIRECT_BASE_URL
###############################################################################

# Server (defaults to 8081 per application.properties)
# SERVER_PORT=8081

# H2 (defaults to file:./data/tailor-studio)
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/tailor-studio;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# PhonePe (disabled by default; enable only after you set credentials)
PHONEPE_ENABLED=false
PHONEPE_SANDBOX=true
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=
PHONEPE_MERCHANT_ID=
# Public URL of this app (no trailing slash). Used for redirect after checkout.
PHONEPE_REDIRECT_BASE_URL=http://localhost:8081


PORT=8001
NODE_ENV=development

# Local frontend (Vite)
FRONTEND_URL=http://localhost:5173
BRAND_PUBLIC_URL=http://localhost:5173

# --- Render production ---
# FRONTEND_URL=https://your-app.vercel.app
# BRAND_PUBLIC_URL=https://your-app.vercel.app
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# (optional) preview deploys on *.vercel.app — default true when unset in code
# CORS_ALLOW_VERCEL_PREVIEWS=true
# TRUST_PROXY=true

MONGOURI=mongodb://localhost:27017/tailor-studio

# Min 32 characters — required
JWT_SECRET=tailor-studio-local-dev-jwt-secret-min-32-chars!!
JWT_EXPIRATION_MS=2592000000

OTP_PEPPER=change-me-in-production
STATIC_OTP_ENABLED=false
STATIC_OTP=

EMAIL=you@gmail.com
EMAIL_PASSWORD=your-google-app-password

PHONEPE_ENABLED=false
PHONEPE_SANDBOX=true
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=
PHONEPE_MERCHANT_ID=
# User return URL after PhonePe — must be your Vercel app, not Render
# PHONEPE_REDIRECT_BASE_URL=https://your-app.vercel.app

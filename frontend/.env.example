# --- Local dev (Vite proxy to Node on :8001; leave empty to use proxy only) ---
# VITE_API_BASE_URL=

# Or point directly at local API (no proxy):
VITE_API_BASE_URL=http://localhost:8001

# --- Vercel production (Environment Variables in Vercel dashboard) ---
# Required: your Render backend URL, no trailing slash
# VITE_API_BASE_URL=https://tailor-studio-api.onrender.com
